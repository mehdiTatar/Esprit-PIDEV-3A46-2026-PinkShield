<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.ParapharmacieController" spacing="15" style="-fx-padding: 20;">

    <Label text="Parapharmacie Management" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <TextField fx:id="searchBar" promptText="Search by product name..." prefHeight="35"/>

    <GridPane hgap="10" vgap="10" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;">
        <columnConstraints>
            <ColumnConstraints prefWidth="100"/>
            <ColumnConstraints prefWidth="200" hgrow="ALWAYS"/>
            <ColumnConstraints prefWidth="80"/>
            <ColumnConstraints prefWidth="150" hgrow="ALWAYS"/>
            <ColumnConstraints prefWidth="80"/>
            <ColumnConstraints prefWidth="150" hgrow="ALWAYS"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints/>
        </rowConstraints>

        <Label text="Product Name:" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtNom" GridPane.columnIndex="1" promptText="Enter product name"/>

        <Label text="Price:" GridPane.columnIndex="2" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtPrix" GridPane.columnIndex="3" promptText="0.00"/>

        <Label text="Stock:" GridPane.columnIndex="4" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtStock" GridPane.columnIndex="5" promptText="0"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Ajouter" onAction="#handleAjouter" style="-fx-padding: 10px 25px; -fx-font-size: 12;"/>
        <Button text="Supprimer" onAction="#handleSupprimer" style="-fx-padding: 10px 25px; -fx-font-size: 12;"/>
    </HBox>

    <TableView fx:id="tableParapharmacie" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colNom" text="Product Name" prefWidth="200"/>
            <TableColumn fx:id="colPrix" text="Price" prefWidth="120"/>
            <TableColumn fx:id="colStock" text="Stock" prefWidth="120"/>
        </columns>
    </TableView>

</VBox>

