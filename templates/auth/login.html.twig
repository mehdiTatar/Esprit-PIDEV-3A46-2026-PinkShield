    .btn-face-upload  { background: #fff; color: #4b5563; border: 1.5px solid #e5e7eb; }
    .btn-face-upload:hover { border-color: var(--primary,#c0396b); color: var(--primary,#c0396b); }

    .btn-face-login {
        width: 100%;
        margin-top: 18px;
        padding: 14px;
        background: linear-gradient(135deg, var(--primary, #c0396b), #9b2553);
        color: #fff;
        border: none;
