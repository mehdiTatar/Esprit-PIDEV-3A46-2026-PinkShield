<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.ParapharmacieController" spacing="15" stylesheets="@style.css" style="-fx-padding: 20;">

    <Label text="💊 Parapharmacie Management" styleClass="label-title"/>

    <TextField fx:id="searchBar" promptText="🔍 Search by product name..." prefHeight="35" styleClass="text-field"/>

    <VBox styleClass="card-pane" spacing="15">
        <Label text="Product Details" style="-fx-font-size: 14; -fx-font-weight: bold;"/>

        <GridPane hgap="15" vgap="12">
            <columnConstraints>
                <ColumnConstraints prefWidth="120"/>
                <ColumnConstraints prefWidth="200" hgrow="ALWAYS"/>
                <ColumnConstraints prefWidth="100"/>
                <ColumnConstraints prefWidth="150" hgrow="ALWAYS"/>
                <ColumnConstraints prefWidth="100"/>
                <ColumnConstraints prefWidth="150" hgrow="ALWAYS"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints/>
            </rowConstraints>

            <Label text="Product Name:" GridPane.columnIndex="0" styleClass="label-subtitle"/>
            <TextField fx:id="txtNom" GridPane.columnIndex="1" promptText="Enter product name" styleClass="text-field"/>

            <Label text="Price:" GridPane.columnIndex="2" styleClass="label-subtitle"/>
            <TextField fx:id="txtPrix" GridPane.columnIndex="3" promptText="0.00" styleClass="text-field"/>

            <Label text="Stock:" GridPane.columnIndex="4" styleClass="label-subtitle"/>
            <TextField fx:id="txtStock" GridPane.columnIndex="5" promptText="0" styleClass="text-field"/>
        </GridPane>
    </VBox>

    <HBox spacing="10">
        <Button text="✅ Ajouter" onAction="#handleAjouter" styleClass="btn-primary"/>
        <Button text="🗑️ Supprimer" onAction="#handleSupprimer" styleClass="btn-danger"/>
    </HBox>

    <TableView fx:id="tableParapharmacie" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colNom" text="Product Name" prefWidth="200"/>
            <TableColumn fx:id="colPrix" text="Price" prefWidth="120"/>
            <TableColumn fx:id="colStock" text="Stock" prefWidth="120"/>
        </columns>
    </TableView>

</VBox>

