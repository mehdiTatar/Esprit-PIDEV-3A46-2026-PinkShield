<<<<<<< HEAD
<!-- Watermark -->
<div class="pat-watermark"><i class="fas fa-heartbeat"></i></div>

<!-- ── Hero Banner ──────────────────────────────────────── -->
<div class="pat-hero">
    <div class="pat-hero-tag">💊 Patient Portal · Your health dashboard</div>
    <h1 class="pat-hero-title">
        Welcome back, <span>{{ app.user.userIdentifier|split('@')|first|title }}</span> 👋
    </h1>
    <div class="pat-hero-sub">
        {{ "now"|date("l, d F Y") }} · Your wellness data and appointments are up to date.
    </div>
    <div class="pat-hero-actions">
        <a href="{{ path('appointment_index') }}" class="pat-btn pat-btn-primary">
            <i class="fas fa-calendar-plus"></i> Book Appointment
        </a>
        <a href="{{ path('tracking_index') }}" class="pat-btn pat-btn-ghost">
            <i class="fas fa-heartbeat"></i> Health Tracking
        </a>
        <a href="{{ path('parapharmacy_index') }}" class="pat-btn pat-btn-ghost">
            <i class="fas fa-pills"></i> Pharmacy
        </a>
    </div>
</div>

<!-- ── Health Vitals ─────────────────────────────────────── -->
<div class="vitals-row">
    <div class="vital-card pink">
        <div class="vital-icon"><i class="fas fa-heartbeat"></i></div>
        <div class="vital-val">{{ heartRate ?? '72' }}</div>
        <div class="vital-unit">bpm · Heart Rate</div>
        <span class="vital-status normal">Normal</span>
    </div>
    <div class="vital-card purple">
        <div class="vital-icon"><i class="fas fa-tint"></i></div>
        <div class="vital-val">{{ bloodPressure ?? '120/80' }}</div>
        <div class="vital-unit">mmHg · Blood Pressure</div>
        <span class="vital-status normal">Normal</span>
    </div>
    <div class="vital-card teal">
        <div class="vital-icon"><i class="fas fa-weight"></i></div>
        <div class="vital-val">{{ weight ?? '68.5' }}</div>
        <div class="vital-unit">kg · Body Weight</div>
        <span class="vital-status normal">On Track</span>
    </div>
    <div class="vital-card orange">
        <div class="vital-icon"><i class="fas fa-fire"></i></div>
        <div class="vital-val">{{ steps ?? '6.2k' }}</div>
        <div class="vital-unit">steps · Daily Activity</div>
        <span class="vital-status warn">Below Goal</span>
    </div>
</div>

<!-- ── Main Grid ────────────────────────────────────────── -->
<div class="pat-grid">
    <!-- Upcoming Appointments -->
    <div class="pat-panel">
        <div class="pat-panel-header">
            <div class="pat-panel-title"><i class="fas fa-calendar-alt"></i> Upcoming Appointments</div>
            <a href="{{ path('appointment_index') }}" class="pat-panel-action">View All →</a>
        </div>
        <div class="pat-panel-body">
            {% if appointments is defined and appointments %}
                {% for appt in appointments|slice(0,3) %}
                <div class="upco-item">
                    <div class="upco-date">
                        <div class="upco-day">{{ appt.appointmentDate is defined ? appt.appointmentDate|date('d') : '15' }}</div>
                        <div class="upco-month">{{ appt.appointmentDate is defined ? appt.appointmentDate|date('M') : 'Mar' }}</div>
                    </div>
                    <div class="upco-info">
                        <div class="upco-doc">
                            Dr. {{ appt.doctor is defined ? appt.doctor.email|split('@')|first : 'Doctor' }}
                        </div>
                        <div class="upco-spec">
                            {{ appt.reason is defined ? appt.reason : 'Consultation' }}
                            · {{ appt.appointmentDate is defined ? appt.appointmentDate|date('H:i') : '10:00' }}
                        </div>
                    </div>
                    <span class="upco-tag {{ appt.status is defined and appt.status == 'confirmed' ? 'confirmed' : 'pending' }}">
                        {{ appt.status is defined ? appt.status|capitalize : 'Pending' }}
                    </span>
                </div>
                {% endfor %}
            {% else %}
                <div class="upco-item">
                    <div class="upco-date"><div class="upco-day">15</div><div class="upco-month">Mar</div></div>
                    <div class="upco-info"><div class="upco-doc">Dr. Khalil Amara</div><div class="upco-spec">Cardiology · 10:00 AM</div></div>
                    <span class="upco-tag confirmed">Confirmed</span>
                </div>
                <div class="upco-item">
                    <div class="upco-date"><div class="upco-day">22</div><div class="upco-month">Mar</div></div>
                    <div class="upco-info"><div class="upco-doc">Dr. Leila Ben Hadj</div><div class="upco-spec">Dermatology · 2:30 PM</div></div>
                    <span class="upco-tag pending">Pending</span>
                </div>
                <div class="upco-item" style="padding-bottom:0;">
                    <div style="text-align:center;width:100%;padding:16px 0;color:rgba(255,255,255,0.2);">
                        <i class="fas fa-calendar-plus" style="display:block;font-size:1.5rem;margin-bottom:6px;opacity:0.3;"></i>
                        <a href="{{ path('appointment_index') }}" class="pat-btn pat-btn-primary" style="font-size:0.78rem;padding:8px 16px;">
                            + Book new appointment
                        </a>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Health Tracking Summary -->
    <div class="pat-panel">
        <div class="pat-panel-header">
            <div class="pat-panel-title"><i class="fas fa-chart-line"></i> Health Timeline</div>
            <a href="{{ path('tracking_index') }}" class="pat-panel-action">Track →</a>
        </div>
        <div class="pat-panel-body">
            {% if trackings is defined and trackings %}
                {% for tracking in trackings|slice(0,4) %}
                <div class="track-item">
                    <div class="track-dot-wrap">
                        <div class="track-dot"></div>
                        {% if not loop.last %}<div class="track-line"></div>{% endif %}
                    </div>
                    <div>
                        <div class="track-label">{{ tracking.type is defined ? tracking.type : 'Health Check' }}</div>
                        <div class="track-value">{{ tracking.value is defined ? tracking.value : 'Recorded' }} · {{ tracking.createdAt is defined ? tracking.createdAt|date('M d') : 'Today' }}</div>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <div class="track-item">
                    <div class="track-dot-wrap"><div class="track-dot"></div><div class="track-line"></div></div>
                    <div><div class="track-label">Blood Pressure Logged</div><div class="track-value">120/80 mmHg · Today</div></div>
                </div>
                <div class="track-item">
                    <div class="track-dot-wrap"><div class="track-dot"></div><div class="track-line"></div></div>
                    <div><div class="track-label">Weight Recorded</div><div class="track-value">68.5 kg · Yesterday</div></div>
                </div>
                <div class="track-item">
                    <div class="track-dot-wrap"><div class="track-dot"></div><div class="track-line"></div></div>
                    <div><div class="track-label">Heart Rate</div><div class="track-value">72 bpm · 2 days ago</div></div>
                </div>
                <div class="track-item">
                    <div class="track-dot-wrap"><div class="track-dot"></div></div>
                    <div><div class="track-label">Steps Goal</div><div class="track-value">6,200 / 10,000 steps · Today</div></div>
                </div>
            {% endif %}
            <div style="margin-top:16px;text-align:center;">
                <a href="{{ path('tracking_index') }}" class="pat-btn pat-btn-ghost" style="font-size:0.78rem;">
                    <i class="fas fa-plus"></i> Log Vital
                </a>
            </div>
        </div>
    </div>
</div>

