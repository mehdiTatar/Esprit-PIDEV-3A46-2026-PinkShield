    .btn-face-capture { background: #22c55e; color: #fff; }
    .btn-face-capture:disabled { background: #e5e7eb; color: #9ca3af; cursor: not-allowed; }
    .btn-face-capture:not(:disabled):hover { background: #16a34a; transform: translateY(-1px); }
    .btn-face-retake  { background: #f59e0b; color: #fff; }
