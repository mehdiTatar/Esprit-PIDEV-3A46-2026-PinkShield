@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Orbitron:wght@400;700;900&display=swap');

/* ── Reset & base ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
    font-family: 'Inter', sans-serif;
    background: #050d1a;
    min-height: 100vh;
    overflow-x: hidden;
    color: #fff;
}

.navbar { display: none !important; }
aside.sidebar, .sidebar-toggle-btn { display: none !important; }
footer, .site-footer { display: none !important; }
main { margin: 0 !important; padding: 0 !important; width: 100% !important; }
.container-desktop { max-width: 100% !important; padding: 0 !important; }

/* ── Animated starfield background ── */
#starfield {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background: radial-gradient(ellipse at 20% 50%, #0a1628 0%, #050d1a 60%, #000 100%);
}

.particle {
    position: absolute; border-radius: 50%;
    animation: floatParticle linear infinite;
    opacity: 0;
}

@keyframes floatParticle {
    0%   { transform: translateY(100vh) scale(0); opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 0.6; }
    100% { transform: translateY(-10vh) scale(1.2); opacity: 0; }
}

/* ── Grid lines overlay ── */
.grid-overlay {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background-image:
        linear-gradient(rgba(192,57,107,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(192,57,107,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    animation: gridPulse 4s ease-in-out infinite;
}
@keyframes gridPulse {
    0%, 100% { opacity: 0.5; }
    50%       { opacity: 1; }
}

/* ── Main layout ── */
.login-page {
    position: relative; z-index: 1;
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    padding: 40px 20px;
}

.login-layout {
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: 60px;
    max-width: 1200px;
    width: 100%;
    align-items: center;
}

/* ── Hero / SVG side ── */
.hero-side {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    position: relative;
}

.brand-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 3.2rem;
    font-weight: 900;
    background: linear-gradient(135deg, #ff4b8d, #c0396b, #ff6ba8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 2px;
    margin-bottom: 10px;
    animation: titleGlow 3s ease-in-out infinite;
}
@keyframes titleGlow {
    0%, 100% { filter: drop-shadow(0 0 12px rgba(192,57,107,0.6)); }
    50%       { filter: drop-shadow(0 0 28px rgba(255,75,141,0.9)); }
}

.brand-tagline {
    font-size: 1rem; color: #7ca3c8; letter-spacing: 3px;
    text-transform: uppercase; margin-bottom: 40px;
    animation: fadeSlideUp 1s ease 0.3s both;
}

/* ── Animated Heart SVG Container ── */
.heart-container {
    position: relative;
    width: 420px; height: 420px;
    animation: floatHeart 6s ease-in-out infinite;
}
@keyframes floatHeart {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    25%       { transform: translateY(-18px) rotate(1deg); }
    75%       { transform: translateY(10px) rotate(-3deg); }
}

/* Orbiting rings */
.orbit-ring {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(192,57,107,0.25);
    top: 50%; left: 50%;
    transform-origin: center center;
}
.orbit-ring-1 { width: 380px; height: 380px; margin: -190px 0 0 -190px; animation: orbitSpin 12s linear infinite; }
.orbit-ring-2 { width: 460px; height: 460px; margin: -230px 0 0 -230px; animation: orbitSpin 20s linear infinite reverse; border-color: rgba(100,200,255,0.15); border-style: dashed; }
.orbit-ring-3 { width: 320px; height: 320px; margin: -160px 0 0 -160px; animation: orbitSpin 8s linear infinite; border-color: rgba(192,57,107,0.15); }

@keyframes orbitSpin { to { transform: rotate(360deg); } }

/* Orbiting dots */
.orbit-dot {
    position: absolute; border-radius: 50%;
    top: 50%; left: 50%;
    transform-origin: 0 0;
}
.orbit-dot::after {
    content: '';
    position: absolute;
    width: 10px; height: 10px; border-radius: 50%;
    background: #c0396b;
    box-shadow: 0 0 14px #ff4b8d;
    top: -5px; left: -5px;
}
.orbit-dot-1 { animation: dotOrbit1 5s linear infinite; }
.orbit-dot-2 { animation: dotOrbit2 8s linear infinite; }
.orbit-dot-2::after { background: #64c8ff; box-shadow: 0 0 14px #64c8ff; width: 7px; height: 7px; }

@keyframes dotOrbit1 {
    from { transform: rotate(0deg) translateX(190px); }
    to   { transform: rotate(360deg) translateX(190px); }
}
@keyframes dotOrbit2 {
    from { transform: rotate(90deg) translateX(230px); }
    to   { transform: rotate(450deg) translateX(230px); }
}

/* ── The actual SVG heart ── */
.heart-svg-wrap {
    position: absolute;
    inset: 0; display: flex; align-items: center; justify-content: center;
}
#heartSvg {
    width: 280px; height: 280px;
    filter: drop-shadow(0 0 30px rgba(192,57,107,0.7)) drop-shadow(0 0 60px rgba(255,75,141,0.4));
}

/* Heart beat animation */
.heart-main {
    animation: heartBeat 1.2s ease-in-out infinite;
    transform-origin: 50% 50%;
}
@keyframes heartBeat {
    0%   { transform: scale(1); }
    14%  { transform: scale(1.08); }
    28%  { transform: scale(1); }
    42%  { transform: scale(1.05); }
    70%  { transform: scale(1); }
    100% { transform: scale(1); }
}

/* Vein pulse */
.vein-path {
    stroke-dashoffset: 0;
    animation: veinFlow 2s ease-in-out infinite;
}
@keyframes veinFlow {
    0%   { opacity: 0.4; }
    50%  { opacity: 1; }
    100% { opacity: 0.4; }
}

/* EKG line */
.ekg-container {
    position: absolute;
    bottom: -20px; left: 50%; transform: translateX(-50%);
    width: 340px;
}
.ekg-svg { width: 100%; height: 60px; }
.ekg-path {
    stroke-dasharray: 800;
    stroke-dashoffset: 800;
    animation: ekgDraw 2s ease-in-out infinite;
}
@keyframes ekgDraw {
    0%   { stroke-dashoffset: 800; opacity: 0; }
    10%  { opacity: 1; }
    60%  { stroke-dashoffset: 0; }
    90%  { stroke-dashoffset: 0; opacity: 1; }
    100% { stroke-dashoffset: 0; opacity: 0; }
}

/* Floating health pills */
.floating-pills {
    position: absolute; inset: 0; pointer-events: none;
}
.pill {
    position: absolute;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(192,57,107,0.3);
    border-radius: 12px;
    padding: 6px 14px;
    font-size: 0.72rem;
    font-weight: 600;
    color: #c0396b;
    display: flex; align-items: center; gap: 6px;
    backdrop-filter: blur(8px);
    animation: pillFloat linear infinite;
    white-space: nowrap;
}
.pill i { font-size: 0.8rem; }

.pill-1 { top: 10%; left: 5%;  animation-duration: 7s;  animation-delay: 0s; }
.pill-2 { top: 20%; right: 0%; animation-duration: 9s;  animation-delay: 1s; }
.pill-3 { top: 70%; left: 0%;  animation-duration: 8s;  animation-delay: 2s; }
.pill-4 { top: 80%; right: 5%; animation-duration: 10s; animation-delay: 0.5s; }
.pill-5 { top: 50%; left: -2%; animation-duration: 6s;  animation-delay: 3s; }

@keyframes pillFloat {
    0%   { transform: translateY(0) rotate(-2deg); }
    33%  { transform: translateY(-12px) rotate(2deg); }
    66%  { transform: translateY(6px) rotate(-1deg); }
    100% { transform: translateY(0) rotate(-2deg); }
}

/* ── Form side ── */
.form-side {
    position: relative;
    animation: fadeSlideUp 0.8s ease 0.2s both;
}

@keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
}

.glass-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(192,57,107,0.2);
    border-radius: 28px;
    padding: 48px 44px;
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow:
        0 0 0 1px rgba(192,57,107,0.1),
        0 30px 80px rgba(0,0,0,0.5),
        inset 0 1px 0 rgba(255,255,255,0.05);
    position: relative; overflow: hidden;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
}
.glass-card:hover {
    transform: translateY(-4px);
    box-shadow:
        0 0 0 1px rgba(192,57,107,0.25),
        0 40px 100px rgba(0,0,0,0.6),
        0 0 60px rgba(192,57,107,0.08),
        inset 0 1px 0 rgba(255,255,255,0.08);
}

/* Glow corners */
.glass-card::before {
    content: '';
    position: absolute; top: -1px; left: -1px; right: -1px; height: 1px;
    background: linear-gradient(90deg, transparent, #c0396b, transparent);
    animation: borderGlow 3s ease-in-out infinite;
}
@keyframes borderGlow {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 1; }
}

.card-header-row {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 8px;
}
.card-icon {
    width: 46px; height: 46px; border-radius: 14px;
    background: linear-gradient(135deg, #c0396b, #9b2553);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; color: #fff;
    box-shadow: 0 8px 20px rgba(192,57,107,0.4);
    animation: iconPulse 2s ease-in-out infinite;
}
@keyframes iconPulse {
    0%, 100% { box-shadow: 0 8px 20px rgba(192,57,107,0.4); }
    50%       { box-shadow: 0 8px 32px rgba(192,57,107,0.7); }
}

.card-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.5rem; font-weight: 700;
    background: linear-gradient(135deg, #fff, #f3a0c0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}
.card-subtitle {
    color: #526a82; font-size: 0.85rem;
    margin-bottom: 34px; letter-spacing: 0.3px;
}

/* Status line */
.status-bar {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 28px; padding: 10px 14px;
    background: rgba(16,185,129,0.06);
    border: 1px solid rgba(16,185,129,0.2);
    border-radius: 10px;
}
.status-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #10b981;
    box-shadow: 0 0 8px #10b981;
    animation: statusBlink 2s ease-in-out infinite;
    flex-shrink: 0;
}
@keyframes statusBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
}
.status-text { font-size: 0.78rem; color: #10b981; font-weight: 500; }

/* ── Alert ── */
.alert-danger-custom {
    display: flex; align-items: flex-start; gap: 10px;
    background: rgba(220,53,69,0.08);
    border: 1px solid rgba(220,53,69,0.3);
    border-radius: 12px; padding: 14px 16px;
    margin-bottom: 24px; color: #ff6b6b; font-size: 0.85rem;
}
.alert-dismiss {
    margin-left: auto; background: none; border: none;
    color: #ff6b6b; cursor: pointer; font-size: 1rem; opacity: 0.7;
}
.alert-dismiss:hover { opacity: 1; }

/* ── Form fields ── */
.field-group { margin-bottom: 18px; position: relative; }

.field-label {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.78rem; font-weight: 600;
    color: #7ca3c8; text-transform: uppercase; letter-spacing: 1px;
    margin-bottom: 8px;
}
.field-label i { color: #c0396b; font-size: 0.75rem; }

.field-input-wrap { position: relative; }

.field-input {
    width: 100%;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 14px 48px 14px 18px;
    font-size: 0.92rem; color: #fff;
    font-family: 'Inter', sans-serif;
    transition: all 0.3s ease;
    outline: none;
}
.field-input::placeholder { color: rgba(255,255,255,0.2); }
.field-input:hover { border-color: rgba(192,57,107,0.3); background: rgba(255,255,255,0.04); }
.field-input:focus {
    border-color: #c0396b;
    background: rgba(192,57,107,0.05);
    box-shadow: 0 0 0 3px rgba(192,57,107,0.12), 0 0 20px rgba(192,57,107,0.08);
}
.field-input.is-invalid { border-color: #ff4444; }

.field-icon {
    position: absolute; right: 16px; top: 50%; transform: translateY(-50%);
    color: rgba(255,255,255,0.2); font-size: 0.9rem; pointer-events: none;
    transition: color 0.3s ease;
}
.field-input:focus ~ .field-icon { color: #c0396b; }

.toggle-pw {
    position: absolute; right: 16px; top: 50%; transform: translateY(-50%);
    background: none; border: none; color: rgba(255,255,255,0.2);
    cursor: pointer; font-size: 0.9rem; padding: 0;
    transition: color 0.3s ease;
}
.toggle-pw:hover { color: #c0396b; }

/* Captcha wrapper */
.captcha-wrap {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 12px;
    display: flex; justify-content: center;
}

/* ── Actions row ── */
.actions-row {
    display: flex; align-items: center; justify-content: flex-end;
    margin: 4px 0 24px;
}
.forgot-link {
    font-size: 0.82rem; color: #c0396b; font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
}
.forgot-link:hover { color: #ff6ba8; text-shadow: 0 0 12px rgba(255,107,168,0.5); }

/* ── Submit button ── */
.btn-signin {
    width: 100%;
    background: linear-gradient(135deg, #c0396b 0%, #9b2553 60%, #c0396b 100%);
    background-size: 200% 100%;
    border: none; border-radius: 14px;
    color: #fff; font-size: 1rem; font-weight: 700;
    padding: 16px 24px;
    cursor: pointer; letter-spacing: 0.5px;
    font-family: 'Inter', sans-serif;
    position: relative; overflow: hidden;
    transition: all 0.35s ease;
    box-shadow: 0 8px 28px rgba(192,57,107,0.4);
}
.btn-signin:hover {
    background-position: right center;
    transform: translateY(-2px);
    box-shadow: 0 16px 40px rgba(192,57,107,0.55);
}
.btn-signin:active { transform: translateY(0); }

/* Shimmer on button */
.btn-signin::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.15) 50%, transparent 60%);
    background-size: 200% 100%;
    animation: btnShimmer 2.5s ease infinite;
}
@keyframes btnShimmer {
    0%   { background-position: -200% 0; }
    100% { background-position: 200% 0; }
}

/* ── OR divider ── */
.or-divider {
    display: flex; align-items: center; gap: 14px;
    margin: 24px 0 20px;
    color: rgba(255,255,255,0.2); font-size: 0.75rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 1px;
}
.or-divider::before, .or-divider::after {
    content: ''; flex: 1; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(192,57,107,0.2), transparent);
}

/* ── Face login section ── */
.face-section {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(192,57,107,0.15);
    border-radius: 18px; padding: 20px;
    position: relative; overflow: hidden;
}
.face-section::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(192,57,107,0.5), transparent);
}
.face-header {
    display: flex; align-items: center; gap: 10px;
    font-size: 0.88rem; font-weight: 700; color: #c0396b;
    margin-bottom: 16px;
}
.face-badge {
    margin-left: auto;
    background: rgba(192,57,107,0.15);
    border: 1px solid rgba(192,57,107,0.3);
    color: #ff6ba8; font-size: 0.62rem; font-weight: 800;
    padding: 3px 10px; border-radius: 30px;
    text-transform: uppercase; letter-spacing: 0.5px;
}
.face-preview-row { display: flex; gap: 14px; }

.webcam-box {
    flex: 1; border-radius: 12px; overflow: hidden;
    background: #000; aspect-ratio: 4/3;
    border: 1px solid rgba(255,255,255,0.07);
    position: relative;
}
#loginWebcamVideo, #loginCapturedCanvas {
    width: 100%; display: block; object-fit: cover;
}
#loginCapturedCanvas { display: none; }

.face-controls { display: flex; flex-direction: column; gap: 8px; width: 130px; flex-shrink: 0; }

.btn-face {
    padding: 9px 12px; border-radius: 10px; border: none;
    font-size: 0.78rem; font-weight: 700; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 6px;
    transition: all 0.2s ease; width: 100%; font-family: 'Inter', sans-serif;
}
.btn-face-open    { background: rgba(255,255,255,0.06); color: #fff; border: 1px solid rgba(255,255,255,0.1); }
.btn-face-open:hover { background: rgba(255,255,255,0.12); transform: translateY(-1px); }
.btn-face-capture { background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid rgba(34,197,94,0.3); }
.btn-face-capture:disabled { opacity: 0.35; cursor: not-allowed; }
.btn-face-capture:not(:disabled):hover { background: rgba(34,197,94,0.25); transform: translateY(-1px); }
.btn-face-retake  { background: rgba(245,158,11,0.15); color: #f59e0b; border: 1px solid rgba(245,158,11,0.3); }
.btn-face-retake:hover { background: rgba(245,158,11,0.25); }
.btn-face-upload  { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.08); cursor: pointer; }
.btn-face-upload:hover { border-color: rgba(192,57,107,0.4); color: #c0396b; }

.face-feedback {
    margin-top: 12px; font-size: 0.8rem; font-weight: 600;
    padding: 10px 14px; border-radius: 10px; display: none;
    animation: fadeSlideUp 0.3s ease;
}
.face-feedback.captured { display: flex; align-items: center; gap: 8px; background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2); }
.face-feedback.scanning { display: flex; align-items: center; gap: 8px; background: rgba(37,99,235,0.1); color: #60a5fa; border: 1px solid rgba(37,99,235,0.2); }
.face-feedback.error    { display: flex; align-items: center; gap: 8px; background: rgba(220,53,69,0.1); color: #ff6b6b; border: 1px solid rgba(220,53,69,0.2); }
.face-feedback.success  { display: flex; align-items: center; gap: 8px; background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2); }

.btn-face-login {
    width: 100%; margin-top: 14px; padding: 13px;
    background: linear-gradient(135deg, rgba(192,57,107,0.2), rgba(155,37,83,0.2));
    color: #ff6ba8; border: 1px solid rgba(192,57,107,0.3); border-radius: 12px;
    font-size: 0.9rem; font-weight: 700; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: all 0.3s ease; font-family: 'Inter', sans-serif;
}
.btn-face-login:hover:not(:disabled) {
    background: linear-gradient(135deg, rgba(192,57,107,0.35), rgba(155,37,83,0.35));
    box-shadow: 0 8px 24px rgba(192,57,107,0.3);
    transform: translateY(-2px);
}
.btn-face-login:disabled { opacity: 0.35; cursor: not-allowed; }

/* ── Register section ── */
.register-row {
    margin-top: 28px; text-align: center;
    font-size: 0.85rem; color: rgba(255,255,255,0.3);
}
.register-row a {
    color: #c0396b; font-weight: 700; text-decoration: none;
    margin-left: 6px; transition: all 0.2s ease;
}
.register-row a:hover { color: #ff6ba8; text-shadow: 0 0 10px rgba(255,107,168,0.4); }

/* ── AJAX error ── */
.ajax-error { display: none; color: #ff6b6b; font-size: 0.78rem; margin-top: 5px; font-weight: 500; }
.ajax-error.d-block { display: block !important; }
.invalid-feedback { display: none !important; }

/* ── Responsive ── */
@media (max-width: 900px) {
    .login-layout { grid-template-columns: 1fr; }
    .hero-side { display: none; }
    .glass-card { padding: 36px 28px; }
}
@media (max-width: 480px) {
    .glass-card { padding: 28px 20px; border-radius: 20px; }
    .card-title { font-size: 1.25rem; }
    .face-preview-row { flex-direction: column; }
    .face-controls { width: 100%; flex-direction: row; flex-wrap: wrap; }
    .btn-face { width: calc(50% - 4px); }
}
