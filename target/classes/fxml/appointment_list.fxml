<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AppointmentListController"
      alignment="TOP_CENTER"
      maxWidth="1160"
      spacing="20"
      styleClass="content-area">
    <padding>
        <Insets top="0" right="0" bottom="0" left="0" />
    </padding>

    <VBox spacing="8" styleClass="hero-panel">
        <Label text="Appointments" styleClass="dashboard-title" />
        <Label text="Review bookings, filter by status, and keep consultations organized in one place." styleClass="dashboard-copy" wrapText="true" />
    </VBox>

    <VBox spacing="16" styleClass="panel-card" VBox.vgrow="ALWAYS">
        <HBox spacing="12" alignment="CENTER_LEFT">
            <ComboBox fx:id="statusFilter" prefWidth="180" styleClass="dashboard-filter" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="bookAppointmentButton" text="Book appointment" onAction="#handleNewAppointment" styleClass="button" />
        </HBox>

        <TableView fx:id="appointmentsTable" VBox.vgrow="ALWAYS" styleClass="dashboard-table">
            <columns>
                <TableColumn fx:id="dateColumn" text="Date and time" prefWidth="190" />
                <TableColumn fx:id="doctorPatientColumn" text="Doctor / Patient" prefWidth="230" />
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="130" />
                <TableColumn fx:id="notesColumn" text="Notes" prefWidth="350" />
                <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="120" />
            </columns>
        </TableView>
    </VBox>
</VBox>
