{% block title %}Patient Dashboard — PinkShield{% endblock %}

{% block stylesheets %}
<style>
    /* ── Dashboard layout ── */
    .dashboard-wrap { display: flex; flex-direction: column; gap: 28px; }

    /* ── Welcome header ── */
    .dashboard-header {
        background: linear-gradient(135deg, var(--primary) 0%, #e8557a 100%);
        color: #fff;
        padding: 36px 40px;
        border-radius: 16px;
        box-shadow: 0 6px 24px rgba(192, 57, 107, 0.22);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
    }

    .dashboard-header-text h1 {
        font-size: 2rem;
        font-weight: 800;
        margin: 0 0 6px;
        letter-spacing: -0.4px;
    }

    .dashboard-header-text p {
        margin: 0;
        opacity: 0.88;
        font-size: 0.95rem;
    }

    .header-date {
        background: rgba(255,255,255,0.18);
        backdrop-filter: blur(6px);
        border-radius: 10px;
        padding: 10px 18px;
        font-size: 0.85rem;
        font-weight: 600;
        white-space: nowrap;
    }

    /* ── Quick actions bar ── */
    .quick-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .quick-action-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 18px;
        border-radius: 10px;
        font-size: 0.88rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.22s ease;
        border: 2px solid transparent;
    }

    .quick-action-btn.primary {
        background: var(--primary);
        color: #fff;
    }

    .quick-action-btn.primary:hover {
        background: var(--primary-dark);
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(192,57,107,0.3);
    }

    .quick-action-btn.outline {
        background: #fff;
        color: var(--primary);
        border-color: var(--primary);
    }

    .quick-action-btn.outline:hover {
        background: var(--primary-light);
        transform: translateY(-2px);
    }

    /* ── Stats row ── */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
    }

    .stat-card {
        background: #fff;
        border-radius: 14px;
        padding: 24px 20px;
        box-shadow: var(--shadow-sm);
        border-left: 4px solid var(--primary);
        display: flex;
        align-items: center;
        gap: 16px;
        transition: var(--transition);
        text-decoration: none;
        color: inherit;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
        color: inherit;
    }

    .stat-icon {
        font-size: 1.8rem;
        color: var(--primary);
        flex-shrink: 0;
        width: 48px;
        height: 48px;
        background: var(--primary-light);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .stat-info h4 {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--text-dark);
        margin: 0 0 2px;
        line-height: 1;
    }

    .stat-info p {
        font-size: 0.82rem;
        color: var(--text-gray);
        margin: 0;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

    /* ── Main content grid ── */
    .content-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    /* ── Cards ── */
    .panel-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        transition: var(--transition);
    }

    .panel-card:hover {
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
    }

    .panel-card-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: #fff;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .panel-card-header i { font-size: 1.3rem; }

    .panel-card-header h5 {
        margin: 0;
        font-weight: 700;
        font-size: 1.05rem;
    }

    .panel-card-header small {
        opacity: 0.82;
        font-size: 0.78rem;
        display: block;
    }

    .panel-card-body { padding: 24px; }

    /* ── Profile info ── */
    .profile-info { display: flex; flex-direction: column; gap: 0; }

    .info-row {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 14px 0;
        border-bottom: 1px solid #f3f4f6;
    }

    .info-row:last-child { border-bottom: none; }

    .info-row-icon {
        width: 36px;
        height: 36px;
        background: var(--primary-light);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 0.95rem;
        flex-shrink: 0;
    }

    .info-row-label {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: var(--text-muted);
        display: block;
    }

    .info-row-value {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text-dark);
    }

    /* ── Feature cards ── */
    .feature-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.9rem;
        color: var(--text-gray);
    }

    .feature-item i { color: var(--primary); font-size: 0.85rem; }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        margin-bottom: 14px;
    }

    .status-live    { background: #dcfce7; color: #166534; }
    .status-pending { background: #fef3c7; color: #92400e; }

    /* ── Edit button ── */
    .btn-edit {
        background: var(--primary);
        border: none;
        color: #fff;
        font-weight: 700;
        padding: 12px 18px;
        border-radius: 10px;
        transition: var(--transition);
        display: block;
        width: 100%;
        text-align: center;
        text-decoration: none;
        font-size: 0.9rem;
    }

    .btn-edit:hover {
        background: var(--primary-dark);
        color: #fff;
        transform: translateY(-1.5px);
        box-shadow: 0 4px 14px rgba(192, 57, 107, 0.3);
    }

    /* ── Responsive ── */
    @media (max-width: 1100px) {
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 900px) {
        .content-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 600px) {
        .dashboard-header { padding: 28px 24px; }
        .dashboard-header-text h1 { font-size: 1.5rem; }
        .header-date { display: none; }
        .stats-grid { grid-template-columns: 1fr; }
        .quick-actions { flex-direction: column; }
    }
