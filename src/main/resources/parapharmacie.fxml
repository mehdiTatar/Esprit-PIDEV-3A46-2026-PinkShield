<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.ParapharmacieController" spacing="15" style="-fx-padding: 20; -fx-background-color: #f4f4f9;">

    <Label text="🌿 Gestion Parapharmacie" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>

    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
        <TextField fx:id="txtNom" promptText="Nom du produit"/>
        <TextField fx:id="txtPrix" promptText="Prix ($)"/>
        <TextField fx:id="txtStock" promptText="Stock"/>
        <Button text="➕ Ajouter" onAction="#handleAjouter" style="-fx-background-color: #0984e3; -fx-text-fill: white;"/>
        <Button text="🔄" onAction="#handleRefresh"/>
    </HBox>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="searchBar" promptText="🔍 Rechercher un produit..." prefWidth="300"/>
        <ComboBox fx:id="sortComboBox" promptText="Trier par..." prefWidth="150"/>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="productFlowPane" hgap="20" vgap="20" style="-fx-padding: 10;"/>
    </ScrollPane>

</VBox>