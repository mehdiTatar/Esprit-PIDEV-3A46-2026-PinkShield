{% block title %}Admin Dashboard — PinkShield{% endblock %}

{% block stylesheets %}
<style>
    /* ══════════════════════════════════════════════════════
       ADMIN DASHBOARD — Dark Navy Command Center Theme
    ══════════════════════════════════════════════════════ */

    :root {
        --adm-navy:       #1e293b;
        --adm-navy-mid:   #334155;
        --adm-blue:       #3b82f6;
        --adm-blue-dark:  #2563eb;
        --adm-blue-light: rgba(59, 130, 246, 0.12);
        --adm-red:        #ef4444;
        --adm-amber:      #f59e0b;
        --adm-green:      #22c55e;
        --adm-purple:     #8b5cf6;
        --adm-teal:       #14b8a6;
        --adm-surface:    #f8fafc;
        --adm-border:     #e2e8f0;
    }

    body { background: var(--adm-surface) !important; }

    /* ── Page layout ── */
    .adm-wrap { display: flex; flex-direction: column; gap: 24px; }

    /* ── Command header ── */
    .adm-header {
        background: linear-gradient(135deg, var(--adm-navy) 0%, var(--adm-navy-mid) 100%);
        color: #fff;
        border-radius: 16px;
        padding: 36px 40px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
        box-shadow: 0 8px 32px rgba(30, 41, 59, 0.25);
        position: relative;
        overflow: hidden;
    }

    .adm-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(59,130,246,0.08) 1px, transparent 1px),
            linear-gradient(90deg, rgba(59,130,246,0.08) 1px, transparent 1px);
        background-size: 32px 32px;
        pointer-events: none;
    }

    .adm-header > * { position: relative; z-index: 1; }

    .adm-header-left h1 {
        font-size: 1.9rem;
        font-weight: 800;
        margin: 0 0 6px;
        letter-spacing: -0.4px;
    }

    .adm-header-left p { margin: 0; opacity: 0.7; font-size: 0.9rem; }

    .adm-header-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 6px;
    }

    .system-status {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(34, 197, 94, 0.15);
        border: 1px solid rgba(34, 197, 94, 0.3);
        color: #86efac;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 700;
    }

    .status-dot {
        width: 8px; height: 8px;
        background: #22c55e;
        border-radius: 50%;
        animation: blink 2s infinite;
    }

    @keyframes blink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0.3; }
    }

    .adm-date { font-size: 0.78rem; color: rgba(255,255,255,0.5); font-weight: 500; }

    /* ── KPI strip ── */
    .kpi-strip {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 18px;
    }

    .kpi-card {
        background: #fff;
        border-radius: 14px;
        padding: 24px 20px;
        box-shadow: var(--shadow-sm);
        border-top: 3px solid var(--adm-blue);
        display: flex;
        flex-direction: column;
        gap: 10px;
        text-decoration: none;
        color: inherit;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

    .kpi-card::after {
        content: '';
        position: absolute;
        bottom: 0; right: 0;
        width: 64px; height: 64px;
        border-radius: 50%;
        background: var(--adm-blue-light);
        transform: translate(30%, 30%);
        transition: transform 0.3s ease;
    }

    .kpi-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(59,130,246,0.18); color: inherit; }
    .kpi-card:hover::after { transform: translate(20%, 20%) scale(1.3); }

    .kpi-card.red    { border-top-color: var(--adm-red); }
    .kpi-card.red::after    { background: rgba(239,68,68,0.08); }
    .kpi-card.amber  { border-top-color: var(--adm-amber); }
    .kpi-card.amber::after  { background: rgba(245,158,11,0.08); }
    .kpi-card.green  { border-top-color: var(--adm-green); }
    .kpi-card.green::after  { background: rgba(34,197,94,0.08); }
    .kpi-card.purple { border-top-color: var(--adm-purple); }
    .kpi-card.purple::after { background: rgba(139,92,246,0.08); }
    .kpi-card.teal   { border-top-color: var(--adm-teal); }
    .kpi-card.teal::after   { background: rgba(20,184,166,0.08); }

    .kpi-icon {
        width: 40px; height: 40px;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem;
        background: var(--adm-blue-light);
        color: var(--adm-blue);
        position: relative; z-index: 1;
    }

    .kpi-card.red    .kpi-icon { background: rgba(239,68,68,0.1);   color: var(--adm-red); }
    .kpi-card.amber  .kpi-icon { background: rgba(245,158,11,0.1);  color: var(--adm-amber); }
    .kpi-card.green  .kpi-icon { background: rgba(34,197,94,0.1);   color: var(--adm-green); }
    .kpi-card.purple .kpi-icon { background: rgba(139,92,246,0.1);  color: var(--adm-purple); }
    .kpi-card.teal   .kpi-icon { background: rgba(20,184,166,0.1);  color: var(--adm-teal); }

    .kpi-value {
        font-size: 2rem; font-weight: 800;
        color: var(--adm-navy); line-height: 1;
        position: relative; z-index: 1;
    }

    .kpi-label {
        font-size: 0.74rem; font-weight: 600;
        color: #64748b; text-transform: uppercase;
        letter-spacing: 0.5px;
        position: relative; z-index: 1;
    }

    .kpi-sub {
        font-size: 0.72rem; color: #94a3b8;
        position: relative; z-index: 1;
    }

    /* ── Charts row ── */
    .charts-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1.4fr;
        gap: 18px;
    }

    /* ── Panel ── */
    .adm-panel {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 1px 6px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .adm-panel-header {
        background: var(--adm-navy);
        color: #fff;
        padding: 15px 22px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-weight: 700;
        font-size: 0.9rem;
    }

    .adm-panel-header .header-left { display: flex; align-items: center; gap: 9px; }
    .adm-panel-header i { color: var(--adm-blue); font-size: 1rem; }

    .adm-panel-header .badge-sm {
        font-size: 0.68rem; font-weight: 700;
        background: rgba(59,130,246,0.2);
        color: #93c5fd;
        padding: 2px 8px; border-radius: 10px;
    }

    .adm-panel-body { padding: 22px; }

    .chart-container { position: relative; }
    .chart-container canvas { width: 100% !important; }

    /* ── Main grid ── */
    .adm-grid {
        display: grid;
        grid-template-columns: 1.6fr 1fr;
        gap: 20px;
    }

    /* ── Management table ── */
    .mgmt-table { width: 100%; border-collapse: collapse; }

    .mgmt-table th {
        text-align: left; font-size: 0.7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.5px;
        color: #94a3b8; padding: 0 0 12px;
        border-bottom: 1px solid var(--adm-border);
    }

    .mgmt-table td {
        padding: 11px 0; border-bottom: 1px solid #f1f5f9;
        font-size: 0.87rem; vertical-align: middle;
    }

    .mgmt-table tr:last-child td { border-bottom: none; }

    .mgmt-count { font-size: 1.3rem; font-weight: 800; color: var(--adm-navy); }

    .mgmt-btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 12px; border-radius: 8px; font-size: 0.78rem;
        font-weight: 600; text-decoration: none;
        background: var(--adm-blue-light); color: var(--adm-blue);
        transition: all 0.2s;
    }

    .mgmt-btn:hover { background: var(--adm-blue); color: #fff; }

    /* ── Quick actions ── */
    .quick-actions-list { display: flex; flex-direction: column; gap: 10px; }

    .qa-btn {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 16px; border-radius: 10px; text-decoration: none;
        font-weight: 600; font-size: 0.87rem; transition: all 0.22s ease;
        border: 1.5px solid var(--adm-border); color: var(--adm-navy); background: #fff;
    }

    .qa-btn:hover {
        border-color: var(--adm-blue); background: var(--adm-blue-light);
        color: var(--adm-blue); transform: translateX(4px);
    }

    .qa-btn .qa-icon {
        width: 32px; height: 32px; border-radius: 8px;
        background: var(--adm-blue-light); color: var(--adm-blue);
        display: flex; align-items: center; justify-content: center;
        font-size: 0.85rem; flex-shrink: 0; transition: all 0.22s;
    }

    .qa-btn:hover .qa-icon { background: var(--adm-blue); color: #fff; }

    /* ── Status pill ── */
    .status-pill {
