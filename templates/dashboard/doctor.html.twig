{% block title %}Doctor Dashboard — PinkShield{% endblock %}

{% block stylesheets %}
<style>
    /* ══════════════════════════════════════════════════════
       DOCTOR DASHBOARD — Deep Teal Clinical Theme
       Color palette: #0f766e (teal), #14b8a6, #f0fdfa
    ══════════════════════════════════════════════════════ */

    :root {
        --doc-teal:        #0f766e;
        --doc-teal-mid:    #0d9488;
        --doc-teal-light:  #14b8a6;
        --doc-teal-bg:     rgba(20, 184, 166, 0.1);
        --doc-surface:     #f0fdfa;
        --doc-border:      #ccfbf1;
        --doc-navy:        #134e4a;
        --doc-amber:       #f59e0b;
        --doc-red:         #ef4444;
        --doc-green:       #22c55e;
    }

    body { background: var(--doc-surface) !important; }

    /* ── Page layout ── */
    .doc-wrap { display: flex; flex-direction: column; gap: 24px; }

    /* ── Clinical header ── */
    .doc-header {
        background: linear-gradient(135deg, var(--doc-teal) 0%, var(--doc-navy) 100%);
        color: #fff;
        border-radius: 16px;
        padding: 36px 40px;
        display: flex;
        align-items: center;
        gap: 24px;
        flex-wrap: wrap;
        box-shadow: 0 8px 32px rgba(15, 118, 110, 0.3);
        position: relative;
        overflow: hidden;
    }

    /* Stethoscope watermark */
    .doc-header::after {
        content: '\f0f1';
        font-family: 'Font Awesome 6 Free';
        font-weight: 900;
        position: absolute;
        right: 40px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 8rem;
        opacity: 0.06;
        color: #fff;
        pointer-events: none;
    }

    .doc-header > * { position: relative; z-index: 1; }

    .doc-avatar {
        width: 68px;
        height: 68px;
        border-radius: 50%;
        background: rgba(255,255,255,0.15);
        border: 3px solid rgba(255,255,255,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        flex-shrink: 0;
    }

    .doc-header-text h1 {
        font-size: 1.8rem;
        font-weight: 800;
        margin: 0 0 4px;
        letter-spacing: -0.3px;
    }

    .doc-header-text .speciality-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.25);
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.82rem;
        font-weight: 600;
        margin-top: 6px;
    }

    .doc-header-text p {
        margin: 4px 0 0;
        opacity: 0.75;
        font-size: 0.88rem;
    }

    /* ── Status toggle bar ── */
    .status-bar {
        background: #fff;
        border-radius: 12px;
        padding: 16px 22px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        box-shadow: 0 1px 6px rgba(0,0,0,0.06);
        border-left: 4px solid var(--doc-teal-mid);
        flex-wrap: wrap;
    }

    .status-bar-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .status-indicator {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 700;
        font-size: 0.9rem;
    }

    .status-indicator.active { color: #16a34a; }
    .status-indicator.inactive { color: #dc2626; }

    .status-indicator .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .status-indicator.active .dot   { background: #22c55e; animation: blink 2s infinite; }
    .status-indicator.inactive .dot { background: #ef4444; }

    @keyframes blink {
        0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(34,197,94,0.4); }
        50%       { opacity: 0.7; box-shadow: 0 0 0 4px rgba(34,197,94,0); }
    }

    .status-bar-right { display: flex; gap: 10px; }

    .toggle-btn {
        padding: 8px 18px;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: all 0.22s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .toggle-btn.go-inactive { background: #fef3c7; color: #92400e; }
    .toggle-btn.go-inactive:hover { background: #fbbf24; color: #fff; }
    .toggle-btn.go-active   { background: #dcfce7; color: #166534; }
    .toggle-btn.go-active:hover   { background: #22c55e; color: #fff; }
    .toggle-btn.edit-btn    { background: var(--doc-teal-bg); color: var(--doc-teal); }
    .toggle-btn.edit-btn:hover    { background: var(--doc-teal); color: #fff; }

    /* ── Stats row ── */
    .doc-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 16px;
    }

    .doc-stat {
        background: #fff;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 1px 6px rgba(0,0,0,0.06);
        display: flex;
        align-items: center;
        gap: 14px;
        text-decoration: none;
        color: inherit;
        transition: all 0.22s ease;
        border-bottom: 3px solid var(--doc-teal-light);
    }

    .doc-stat:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(20,184,166,0.15);
        color: inherit;
    }

    .doc-stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: var(--doc-teal-bg);
        color: var(--doc-teal);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .doc-stat-value {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--doc-navy);
        line-height: 1;
    }

    .doc-stat-label {
        font-size: 0.78rem;
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

    /* ── Content grid ── */
    .doc-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    /* ── Feature panel ── */
    .doc-panel {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 1px 6px rgba(0,0,0,0.06);
        overflow: hidden;
        transition: all 0.22s ease;
    }

    .doc-panel:hover {
        box-shadow: 0 6px 24px rgba(20,184,166,0.12);
        transform: translateY(-2px);
    }

    .doc-panel-header {
        background: linear-gradient(135deg, var(--doc-teal) 0%, var(--doc-teal-mid) 100%);
        color: #fff;
        padding: 18px 22px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .doc-panel-header i { font-size: 1.3rem; opacity: 0.9; }

    .doc-panel-header h5 {
        margin: 0;
        font-weight: 700;
        font-size: 0.98rem;
    }

    .doc-panel-header small {
        display: block;
        opacity: 0.75;
        font-size: 0.78rem;
        margin-top: 2px;
    }

    .doc-panel-body { padding: 22px; }

    /* ── Feature list ── */
    .doc-feature-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 18px; }

    .doc-feature-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.87rem;
        color: #475569;
    }

    .doc-feature-item i { color: var(--doc-teal); font-size: 0.8rem; }

    /* ── CTA button ── */
    .doc-cta {
        display: block;
        width: 100%;
        text-align: center;
        padding: 11px 18px;
        background: linear-gradient(135deg, var(--doc-teal) 0%, var(--doc-teal-mid) 100%);
        color: #fff;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.9rem;
        text-decoration: none;
        transition: all 0.22s ease;
    }

    .doc-cta:hover {
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(15,118,110,0.3);
        filter: brightness(1.05);
    }

    /* ── Rating display ── */
    .rating-display {
        text-align: center;
        padding: 10px 0;
    }

    .rating-stars { font-size: 1.5rem; margin-bottom: 6px; }
    .rating-stars .fa-star.filled { color: #fbbf24; }
    .rating-stars .fa-star.empty  { color: #e2e8f0; }
    .rating-score { font-size: 2rem; font-weight: 800; color: var(--doc-navy); }
    .rating-meta  { font-size: 0.82rem; color: #94a3b8; margin-top: 4px; }

    @media (max-width: 1100px) {
        .doc-stats { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 900px) {
        .doc-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 600px) {
        .doc-header { padding: 28px 24px; }
        .doc-header::after { display: none; }
        .doc-header-text h1 { font-size: 1.5rem; }
        .doc-stats { grid-template-columns: 1fr; }
        .status-bar { flex-direction: column; align-items: flex-start; }
    }
