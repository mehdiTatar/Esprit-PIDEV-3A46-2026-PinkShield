<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.controllers.RegisterController"
           fx:id="registerRoot"
           id="registerRoot"
           styleClass="auth-screen">
    <fx:define>
        <ToggleGroup fx:id="roleGroup" />
    </fx:define>

    <children>
        <StackPane maxWidth="1080" prefHeight="700" styleClass="auth-shell">
            <children>
                <HBox fillHeight="true">
                    <VBox prefWidth="385" styleClass="auth-brand-side">
                        <padding>
                            <Insets top="40" right="34" bottom="40" left="34" />
                        </padding>

                        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="auth-logo-row">
                            <StackPane minHeight="44" minWidth="44" prefHeight="44" prefWidth="44" styleClass="auth-logo-mark">
                                <children>
                                    <Label text="P" styleClass="auth-logo-mark-text" />
                                </children>
                            </StackPane>
                            <Label text="PinkShield" styleClass="auth-wordmark" />
                        </HBox>

                        <VBox alignment="CENTER" spacing="18" VBox.vgrow="ALWAYS">
                            <StackPane minHeight="94" minWidth="94" prefHeight="94" prefWidth="94" styleClass="auth-role-badge">
                                <children>
                                    <Label fx:id="roleBadgeLabel" text="P" styleClass="auth-role-badge-text" />
                                </children>
                            </StackPane>
                            <Label fx:id="roleHeadingLabel" text="Join as a Patient" styleClass="auth-role-heading" />
                            <Label fx:id="roleDescriptionLabel"
                                   text="Take control of your health, connect with doctors, and manage your care in one place."
                                   wrapText="true"
                                   textAlignment="CENTER"
                                   styleClass="auth-hero-copy" />
                        </VBox>

                        <VBox spacing="12" styleClass="auth-feature-list">
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="auth-feature-card">
                                <Label text="01" styleClass="auth-feature-icon" />
                                <Label fx:id="benefit1Label" text="Privacy and data protection" wrapText="true" styleClass="auth-benefit-text" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="auth-feature-card">
                                <Label text="02" styleClass="auth-feature-icon" />
                                <Label fx:id="benefit2Label" text="Direct access to doctors" wrapText="true" styleClass="auth-benefit-text" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="auth-feature-card">
                                <Label text="03" styleClass="auth-feature-icon" />
                                <Label fx:id="benefit3Label" text="Centralized health records" wrapText="true" styleClass="auth-benefit-text" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="auth-feature-card">
                                <Label text="04" styleClass="auth-feature-icon" />
                                <Label fx:id="benefit4Label" text="Health reminders and alerts" wrapText="true" styleClass="auth-benefit-text" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS" styleClass="auth-form-side">
                        <ScrollPane fitToWidth="true"
                                    fitToHeight="true"
                                    hbarPolicy="NEVER"
                                    VBox.vgrow="ALWAYS"
                                    styleClass="auth-scroll">
                            <content>
                                <VBox spacing="20" styleClass="auth-register-content">
                                    <padding>
                                        <Insets top="40" right="34" bottom="40" left="34" />
                                    </padding>

                                    <VBox spacing="8">
                                        <Label text="Create your account" styleClass="auth-form-title" />
                                        <Label text="Choose your role and complete the form below to start with PinkShield."
                                               wrapText="true"
                                               styleClass="auth-form-subtitle" />
                                    </VBox>

                                    <VBox spacing="10">
                                        <Label text="I AM A..." styleClass="auth-section-label" />
                                        <HBox spacing="12">
                                            <ToggleButton fx:id="patientToggle"
                                                          text="Patient"
                                                          selected="true"
                                                          toggleGroup="$roleGroup"
                                                          maxWidth="1.7976931348623157E308"
                                                          HBox.hgrow="ALWAYS"
                                                          styleClass="role-toggle" />
                                            <ToggleButton fx:id="doctorToggle"
                                                          text="Doctor"
                                                          toggleGroup="$roleGroup"
                                                          maxWidth="1.7976931348623157E308"
                                                          HBox.hgrow="ALWAYS"
                                                          styleClass="role-toggle" />
                                        </HBox>
                                    </VBox>

                                    <VBox spacing="6" styleClass="auth-summary-card">
                                        <Label fx:id="roleSummaryTitleLabel" text="Patient account" styleClass="auth-summary-title" />
                                        <Label fx:id="roleSummaryTextLabel"
                                               text="Book appointments, review your records, and keep your health information organized."
                                               wrapText="true"
                                               styleClass="auth-summary-text" />
                                    </VBox>

                                    <VBox spacing="7" styleClass="auth-field-block">
                                        <Label text="EMAIL ADDRESS" styleClass="auth-field-label" />
                                        <TextField fx:id="emailField"
                                                   promptText="you@example.com"
                                                   styleClass="auth-input" />
                                        <Label fx:id="emailErrorLabel"
                                               text=""
                                               visible="false"
                                               managed="false"
                                               maxWidth="1.7976931348623157E308"
                                               alignment="CENTER_LEFT"
                                               wrapText="true"
                                               styleClass="field-feedback" />
                                    </VBox>

                                    <VBox fx:id="patientFields" spacing="16">
                                        <HBox spacing="14">
                                            <VBox spacing="7" HBox.hgrow="ALWAYS" styleClass="auth-field-block">
                                                <Label text="FIRST NAME" styleClass="auth-field-label" />
                                                <TextField fx:id="patientFirstNameField"
                                                           promptText="First name"
                                                           styleClass="auth-input" />
                                                <Label fx:id="patientFirstNameErrorLabel"
                                                       text=""
                                                       visible="false"
                                                       managed="false"
                                                       maxWidth="1.7976931348623157E308"
                                                       alignment="CENTER_LEFT"
                                                       wrapText="true"
                                                       styleClass="field-feedback" />
                                            </VBox>
                                            <VBox spacing="7" HBox.hgrow="ALWAYS" styleClass="auth-field-block">
                                                <Label text="LAST NAME" styleClass="auth-field-label" />
                                                <TextField fx:id="patientLastNameField"
                                                           promptText="Last name"
                                                           styleClass="auth-input" />
                                                <Label fx:id="patientLastNameErrorLabel"
                                                       text=""
                                                       visible="false"
                                                       managed="false"
                                                       maxWidth="1.7976931348623157E308"
                                                       alignment="CENTER_LEFT"
                                                       wrapText="true"
                                                       styleClass="field-feedback" />
                                            </VBox>
                                        </HBox>

                                        <VBox spacing="7" styleClass="auth-field-block">
                                            <Label text="PHONE NUMBER" styleClass="auth-field-label" />
                                            <TextField fx:id="phoneField"
                                                       promptText="+213 5XX XXX XXX"
                                                       styleClass="auth-input" />
                                            <Label fx:id="phoneErrorLabel"
                                                   text=""
                                                   visible="false"
                                                   managed="false"
                                                   maxWidth="1.7976931348623157E308"
                                                   alignment="CENTER_LEFT"
                                                   wrapText="true"
                                                   styleClass="field-feedback" />
                                        </VBox>

                                        <VBox spacing="7" styleClass="auth-field-block">
                                            <Label text="ADDRESS" styleClass="auth-field-label" />
                                            <TextField fx:id="addressField"
                                                       promptText="Street, city, and region"
                                                       styleClass="auth-input" />
                                            <Label fx:id="addressErrorLabel"
                                                   text=""
                                                   visible="false"
                                                   managed="false"
                                                   maxWidth="1.7976931348623157E308"
                                                   alignment="CENTER_LEFT"
                                                   wrapText="true"
                                                   styleClass="field-feedback" />
                                        </VBox>
                                    </VBox>

                                    <VBox fx:id="doctorFields" managed="false" visible="false" spacing="16">
                                        <HBox spacing="14">
                                            <VBox spacing="7" HBox.hgrow="ALWAYS" styleClass="auth-field-block">
                                                <Label text="FIRST NAME" styleClass="auth-field-label" />
                                                <TextField fx:id="firstNameField"
                                                           promptText="First name"
                                                           styleClass="auth-input" />
                                                <Label fx:id="firstNameErrorLabel"
                                                       text=""
                                                       visible="false"
                                                       managed="false"
                                                       maxWidth="1.7976931348623157E308"
                                                       alignment="CENTER_LEFT"
                                                       wrapText="true"
                                                       styleClass="field-feedback" />
                                            </VBox>
                                            <VBox spacing="7" HBox.hgrow="ALWAYS" styleClass="auth-field-block">
                                                <Label text="LAST NAME" styleClass="auth-field-label" />
                                                <TextField fx:id="lastNameField"
                                                           promptText="Last name"
                                                           styleClass="auth-input" />
                                                <Label fx:id="lastNameErrorLabel"
                                                       text=""
                                                       visible="false"
                                                       managed="false"
                                                       maxWidth="1.7976931348623157E308"
                                                       alignment="CENTER_LEFT"
                                                       wrapText="true"
                                                       styleClass="field-feedback" />
                                            </VBox>
                                        </HBox>

                                        <VBox spacing="7" styleClass="auth-field-block">
                                            <Label text="MEDICAL SPECIALITY" styleClass="auth-field-label" />
                                            <ComboBox fx:id="specialityField"
                                                      editable="true"
                                                      promptText="Select or type your speciality"
                                                      styleClass="auth-combo" />
                                            <Label fx:id="specialityErrorLabel"
                                                   text=""
                                                   visible="false"
                                                   managed="false"
                                                   maxWidth="1.7976931348623157E308"
                                                   alignment="CENTER_LEFT"
                                                   wrapText="true"
                                                   styleClass="field-feedback" />
                                        </VBox>
                                    </VBox>

                                    <HBox alignment="CENTER" spacing="12" styleClass="auth-section-divider">
                                        <Separator HBox.hgrow="ALWAYS" />
                                        <Label text="SECURITY" styleClass="auth-divider-label" />
                                        <Separator HBox.hgrow="ALWAYS" />
                                    </HBox>

                                    <VBox spacing="16">
                                        <VBox spacing="7" styleClass="auth-field-block">
                                            <Label text="PASSWORD" styleClass="auth-field-label" />
                                            <PasswordField fx:id="passwordField"
                                                           promptText="Minimum 8 characters"
                                                           styleClass="auth-input" />
                                            <Label fx:id="passwordErrorLabel"
                                                   text=""
                                                   visible="false"
                                                   managed="false"
                                                   maxWidth="1.7976931348623157E308"
                                                   alignment="CENTER_LEFT"
                                                   wrapText="true"
                                                   styleClass="field-feedback" />
                                        </VBox>

                                        <VBox spacing="7" styleClass="auth-field-block">
                                            <Label text="CONFIRM PASSWORD" styleClass="auth-field-label" />
                                            <PasswordField fx:id="confirmPasswordField"
                                                           promptText="Re-enter your password"
                                                           styleClass="auth-input" />
                                            <Label fx:id="confirmPasswordErrorLabel"
                                                   text=""
                                                   visible="false"
                                                   managed="false"
                                                   maxWidth="1.7976931348623157E308"
                                                   alignment="CENTER_LEFT"
                                                   wrapText="true"
                                                   styleClass="field-feedback" />
                                        </VBox>
                                    </VBox>

                                    <Label fx:id="feedbackLabel"
                                           text=""
                                           visible="false"
                                           managed="false"
                                           wrapText="true"
                                           styleClass="feedback-label" />

                                    <Button fx:id="registerBtn"
                                            text="Register as Patient"
                                            onAction="#handleRegister"
                                            maxWidth="1.7976931348623157E308"
                                            styleClass="auth-primary-button" />

                                    <HBox alignment="CENTER" spacing="6">
                                        <Label text="Already have an account?" styleClass="auth-inline-text" />
                                        <Hyperlink text="Sign in"
                                                   onAction="#handleBackToLogin"
                                                   styleClass="auth-link" />
                                    </HBox>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </VBox>
                </HBox>
            </children>
        </StackPane>
    </children>
</StackPane>
