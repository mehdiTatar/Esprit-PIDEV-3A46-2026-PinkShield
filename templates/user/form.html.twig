{% extends "base.html.twig" %}

{% block title %}{{ title }} - PinkShield{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-lg">
            <div class="card-body p-5">
                <h2 class="mb-4">{{ title }}</h2>

                {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'userProfileForm'}}) }}

                    <div class="mb-3">
                        {{ form_label(form.email) }}
                        {{ form_widget(form.email, {'attr': {'data-ajax-validate': 'email'}}) }}
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_label(form.firstName) }}
                            {{ form_widget(form.firstName, {'attr': {'data-ajax-validate': 'firstName'}}) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_label(form.lastName) }}
                            {{ form_widget(form.lastName, {'attr': {'data-ajax-validate': 'lastName'}}) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.address) }}
                        {{ form_widget(form.address, {'attr': {'data-ajax-validate': 'address'}}) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.phone) }}
                        {{ form_widget(form.phone, {'attr': {'data-ajax-validate': 'phone'}}) }}
                    </div>

                    {% if form.password is defined %}
                    <div class="mb-3">
                        {{ form_label(form.password) }}
                        {{ form_widget(form.password, {'attr': {'data-ajax-validate': 'password', 'placeholder': 'Leave blank to keep current password'}}) }}
                    </div>
                    {% endif %}

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a href="{% if form.vars.data.id %}{{ path('user_index') }}{% else %}{{ path('login') }}{% endif %}"
                           class="btn btn-secondary">Cancel</a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('userProfileForm');
    if (!form) return;
    AjaxValidator.attachBlur(form);
    AjaxValidator.attachSubmit(form);
});
</script>
{% endblock %}
