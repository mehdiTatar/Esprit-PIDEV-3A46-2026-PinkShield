{% block title %}Create Account · PinkShield{% endblock %}

{% block stylesheets %}
<style>
    /* ─── Override base layout for full-screen register ─── */
    body {
        background: #060e1c !important;
        background-image:
            radial-gradient(ellipse at 20% 0%, rgba(192,57,107,0.12) 0%, transparent 55%),
            radial-gradient(ellipse at 80% 100%, rgba(59,130,246,0.07) 0%, transparent 50%) !important;
    }
    aside.sidebar, .sidebar-toggle-btn { display: none !important; }
    main {
        margin-left: 0 !important; width: 100% !important;
        display: flex; align-items: center; justify-content: center;
        min-height: calc(100vh - 64px); padding: 48px 24px !important;
    }
    footer, .site-footer { margin-left: 0 !important; width: 100% !important; }
    .container-desktop { max-width: 100% !important; padding: 0 !important; width: 100%; display: flex; align-items: center; justify-content: center; }

    /* ─── Starfield ────────────────────────────────────── */
    .reg-stars {
        position: fixed; inset: 0; pointer-events: none;
        overflow: hidden; z-index: 0;
    }
    .reg-star {
        position: absolute; border-radius: 50%;
        background: #fff; animation: twinkle var(--d, 3s) ease-in-out infinite var(--delay, 0s);
    }
    @keyframes twinkle { 0%,100%{opacity:0.1;transform:scale(1);} 50%{opacity:0.7;transform:scale(1.3);} }

    /* ─── Register Card ────────────────────────────────── */
    .register-wrapper {
        width: 100%; display: flex; align-items: center;
        justify-content: center; padding-bottom: 20px;
        position: relative; z-index: 1;
    }
    .register-container {
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        gap: 0; max-width: 1020px; width: 100%;
        background: rgba(8,16,30,0.95);
        border: 1px solid rgba(192,57,107,0.2);
        border-radius: 24px;
        box-shadow: 0 32px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.04);
        overflow: hidden;
        backdrop-filter: blur(20px);
        animation: cardFloat 6s ease-in-out infinite;
    }
    @keyframes cardFloat { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-6px);} }
    .register-container::before {
        content: ''; position: absolute; inset: -1px;
        border-radius: 25px; z-index: -1;
        background: linear-gradient(135deg,
            rgba(192,57,107,0.3) 0%,
            transparent 40%, transparent 60%,
            rgba(59,130,246,0.2) 100%);
        pointer-events: none;
    }

    /* ─── Left Branding Panel ──────────────────────────── */
    .register-branding {
        background: linear-gradient(145deg, rgba(192,57,107,0.15) 0%, rgba(168,85,247,0.08) 100%);
        border-right: 1px solid rgba(192,57,107,0.15);
        padding: 52px 44px;
        display: flex; flex-direction: column;
        justify-content: center; align-items: center;
        text-align: center; position: relative; overflow: hidden;
    }
    .register-branding::before {
        content: ''; position: absolute; inset: 0;
        background: radial-gradient(ellipse at 50% 30%, rgba(192,57,107,0.15) 0%, transparent 70%);
    }

    /* Animated SVG Heart */
    .brand-heart-svg {
        width: 110px; height: 110px; margin-bottom: 24px;
        position: relative; z-index: 1;
    }
    .heart-path {
        fill: #c0396b;
        filter: drop-shadow(0 0 12px rgba(192,57,107,0.6));
        animation: heartBeat 1.5s ease-in-out infinite;
        transform-origin: center;
    }
    @keyframes heartBeat {
        0%,100%{transform:scale(1);} 14%{transform:scale(1.12);}
        28%{transform:scale(1);}    42%{transform:scale(1.07);}
        70%{transform:scale(1);}
    }
    .ekg-path {
        stroke: rgba(192,57,107,0.5); stroke-width: 1.5;
        fill: none; stroke-dasharray: 200;
        animation: ekgDraw 2s linear infinite;
    }
    @keyframes ekgDraw { 0%{stroke-dashoffset:200;} 100%{stroke-dashoffset:-200;} }

    .brand-logo-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 2rem; font-weight: 900; color: #fff;
        letter-spacing: 1px; margin-bottom: 6px;
        text-shadow: 0 0 30px rgba(192,57,107,0.4);
        position: relative; z-index: 1;
    }
    .brand-logo-title span { color: #ff6ba8; }
    .brand-tagline {
        color: rgba(255,255,255,0.35); font-size: 0.84rem;
        margin-bottom: 36px; position: relative; z-index: 1;
    }

    .brand-features {
        display: flex; flex-direction: column; gap: 14px;
        position: relative; z-index: 1; width: 100%;
    }
    .brand-feature {
        display: flex; align-items: center; gap: 12px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(192,57,107,0.12);
        padding: 12px 16px; border-radius: 12px;
        text-align: left; transition: all 0.2s;
    }
    .brand-feature:hover { background: rgba(192,57,107,0.07); border-color: rgba(192,57,107,0.25); }
    .brand-feat-icon {
        width: 36px; height: 36px; border-radius: 10px;
        background: rgba(192,57,107,0.12); color: #ff6ba8;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.9rem; flex-shrink: 0;
    }
    .brand-feat-text { font-size: 0.82rem; font-weight: 600; color: rgba(255,255,255,0.75); }
    .brand-feat-sub  { font-size: 0.68rem; color: rgba(255,255,255,0.3); margin-top: 1px; }

    /* ─── Right Form Panel ─────────────────────────────── */
    .register-form-wrapper {
        padding: 48px 44px;
        display: flex; flex-direction: column; justify-content: center;
        background: rgba(6,14,28,0.8);
    }
    .reg-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 1.4rem; font-weight: 900; color: #fff;
        margin-bottom: 6px; text-align: center;
    }
    .reg-subtitle { text-align: center; color: rgba(255,255,255,0.3); font-size: 0.83rem; margin-bottom: 28px; }

    /* Role Selector */
    .role-selector { margin-bottom: 26px; }
    .role-selector-label {
        font-size: 0.7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 1px;
        color: rgba(255,255,255,0.35); margin-bottom: 10px;
        display: flex; align-items: center; gap: 8px;
    }
    .role-options { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .role-option input[type="radio"] { display: none; }
    .role-label {
        display: flex; align-items: center; justify-content: center;
        gap: 10px; padding: 16px;
        border: 1.5px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        background: rgba(255,255,255,0.03);
        cursor: pointer; transition: all 0.25s;
        font-weight: 600; color: rgba(255,255,255,0.45);
        font-size: 0.9rem;
    }
    .role-label i { font-size: 1.1rem; }
    .role-label:hover { border-color: rgba(192,57,107,0.3); background: rgba(192,57,107,0.06); color: #fff; }
    .role-option input:checked + .role-label {
        border-color: #c0396b;
        background: rgba(192,57,107,0.12);
        color: #ff6ba8;
        box-shadow: 0 0 0 3px rgba(192,57,107,0.15), inset 0 0 12px rgba(192,57,107,0.05);
    }

    /* CTA Button */
    .reg-submit {
        width: 100%;
        background: linear-gradient(135deg, #c0396b 0%, #e8557a 100%);
        border: none; color: #fff;
        font-weight: 700; font-size: 0.95rem;
        padding: 14px; border-radius: 12px;
        cursor: pointer; transition: all 0.25s;
        margin-top: 16px; position: relative; overflow: hidden;
        letter-spacing: 0.3px;
    }
    .reg-submit::after {
        content: ''; position: absolute; inset: 0;
        background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.15) 50%, transparent 60%);
        background-size: 200%; background-position: -200% 0;
        animation: shimmer 2s linear infinite;
    }
    @keyframes shimmer { to { background-position: 200% 0; } }
    .reg-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(192,57,107,0.5); }

    /* Login link */
    .reg-login {
        margin-top: 24px; padding-top: 22px;
        border-top: 1px solid rgba(255,255,255,0.06);
        text-align: center;
    }
    .reg-login p { color: rgba(255,255,255,0.3); font-size: 0.83rem; margin-bottom: 10px; }
    .reg-login-btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 10px 24px; border-radius: 10px;
        border: 1.5px solid rgba(192,57,107,0.3);
        background: rgba(192,57,107,0.06);
        color: #ff6ba8; font-weight: 600; font-size: 0.85rem;
        text-decoration: none; transition: all 0.22s;
    }
    .reg-login-btn:hover { background: rgba(192,57,107,0.15); border-color: rgba(192,57,107,0.5); color: #fff; }

    /* ─── Responsive ─────────────────────────────────────── */
    @media (max-width: 800px) {
        .register-container { grid-template-columns: 1fr; }
        .register-branding  { padding: 32px 28px; }
        .register-form-wrapper { padding: 32px 28px; }
        .brand-features { display: none; }
